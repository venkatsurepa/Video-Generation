{
  "name": "crimemill-video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "render:doc": "remotion render CrimeDocumentary --props sample-props.json",
    "render:short": "remotion render CrimeShort --props sample-short-props.json",
    "render:test": "remotion render CrimeDocumentary --props sample-props.json --frames=0-30",
    "render:lambda": "tsx scripts/render_video.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "deploy": "bash scripts/deploy-lambda.sh",
    "compositions": "remotion compositions src/index.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/lambda": "^4.0.0",
    "@remotion/captions": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/transitions": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0"
  }
}
