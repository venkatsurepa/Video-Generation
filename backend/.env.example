# ============================================================
# CrimeMill — Environment Variables
# ============================================================
# Copy to .env and fill in values. All keys have safe defaults
# except SUPABASE_DB_URL which is required for startup.
# ============================================================

# --- Application ---
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
MAX_CONCURRENT_JOBS=3            # 1-20, pipeline worker concurrency
PIPELINE_POLL_INTERVAL_SECONDS=5 # 1-60, job queue poll interval
HEALTHCHECKS_PING_URL=           # Optional healthchecks.io ping URL
CORS_ALLOWED_ORIGINS=*           # Comma-separated origins; use * for dev, restrict in production

# --- Database (Supabase) ---
SUPABASE_URL=                    # https://<project>.supabase.co
SUPABASE_ANON_KEY=               # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=       # Supabase service role key (server-side only)
SUPABASE_DB_URL=                 # postgresql://postgres:<password>@<host>:5432/postgres

# --- AI: LLM ---
ANTHROPIC_API_KEY=               # Claude API key (required for script generation)
GROQ_API_KEY=                    # Groq API key (optional, for fast inference)

# --- AI: Text-to-Speech ---
FISH_AUDIO_API_KEY=              # Fish Audio TTS API key

# --- AI: Image Generation ---
FAL_AI_API_KEY=                  # FAL.AI API key (Flux image generation)

# --- Object Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=crimemill-assets
R2_PUBLIC_URL=                   # Public URL for R2 bucket (CDN)
R2_ENDPOINT_URL=                 # Override S3 endpoint (defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com); set to http://localhost:9000 for MinIO

# --- Video Rendering (Remotion Lambda) ---
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_AWS_REGION=us-east-1
REMOTION_LAMBDA_FUNCTION_NAME=   # Lambda function name from remotion deploy
REMOTION_SERVE_URL=              # Site URL from `npx remotion lambda sites create`
REMOTION_RENDER_TIMEOUT_MS=300000
REMOTION_FRAMES_PER_LAMBDA=20
REMOTION_RENDER_SCRIPT_PATH=video/scripts/render_video.ts

# --- YouTube ---
YOUTUBE_CLIENT_ID=               # Google Cloud OAuth2 client ID
YOUTUBE_CLIENT_SECRET=           # Google Cloud OAuth2 client secret

# --- Podcast (Buzzsprout) ---
BUZZSPROUT_PODCAST_ID=
BUZZSPROUT_API_KEY=

# --- Budget Enforcement ---
BUDGET_PER_VIDEO_USD=15.0        # Hard cap per video in USD
BUDGET_SOFT_ALERT_PCT=0.70       # Soft alert at 70% of budget
BUDGET_HARD_ALERT_PCT=0.90       # Hard alert at 90% — triggers degradation

# --- Community: Discord ---
DISCORD_WEBHOOK_URL=             # Discord webhook for notifications
DISCORD_BOT_TOKEN=               # Discord bot token (for threads)
DISCORD_GUILD_ID=                # Discord server ID
DISCORD_CASE_DISCUSSION_CHANNEL_ID=  # Channel for case discussions

# --- Community: Patreon ---
PATREON_CAMPAIGN_ID=
PATREON_ACCESS_TOKEN=

# --- Community: Google Forms ---
GOOGLE_FORMS_SHEET_ID=           # Google Sheet ID for form submissions

# --- Cross-Platform Distribution ---
REPURPOSE_IO_API_KEY=            # Repurpose.io API key
REPURPOSE_IO_WORKFLOW_ID=        # Repurpose.io workflow ID
AYRSHARE_API_KEY=                # Ayrshare social media API key (fallback)

# --- Newsletter ---
RESEND_API_KEY=                  # Resend.com API key for email
NEWSLETTER_FROM_EMAIL=noreply@crimemill.com

# --- Research: Court Records ---
COURTLISTENER_API_TOKEN=         # CourtListener / PACER API token

# --- Self-Hosted Infrastructure (optional) ---
# Only needed when using self-hosted providers instead of APIs.
SELF_HOSTED_TTS_URL=             # e.g. http://gpu-host:8880
SELF_HOSTED_IMAGE_URL=           # e.g. http://gpu-host:8188
SELF_HOSTED_MUSIC_URL=           # e.g. http://gpu-host:8890
SELF_HOSTED_TTS_PROVIDER=fish_audio       # fish_audio | chatterbox | kokoro
SELF_HOSTED_IMAGE_PROVIDER=fal_ai         # fal_ai | local_flux
SELF_HOSTED_MUSIC_PROVIDER=epidemic_sound_library  # epidemic_sound_library | ace_step
SELF_HOSTED_LLM_PROVIDER=anthropic        # anthropic



REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_AWS_REGION=us-east-1
